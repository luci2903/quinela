// Esquema de base de datos - Quiniela Mundial 2026
// Prisma ORM + PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
}

enum MatchPhase {
  GROUP_STAGE
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  THIRD_PLACE
  FINAL
}

// ─────────────────────────────────────────────
// Modelos
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships GroupMembership[]
  predictions Prediction[]

  @@map("users")
}

model Group {
  id             String   @id @default(uuid())
  name           String
  invitationCode String   @unique @default(cuid())
  ownerId        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  memberships GroupMembership[]

  @@map("groups")
}

// Tabla intermedia entre User y Group.
// Guarda de forma independiente el score_acumulado del usuario en ese grupo específico.
model GroupMembership {
  id             String   @id @default(uuid())
  scoreAcumulado Int      @default(0) @map("score_acumulado")
  joinedAt       DateTime @default(now())

  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@map("group_memberships")
}

model Match {
  id            String      @id @default(uuid())
  externalId    String?     @unique // id del partido en thesportsdb.com
  homeTeam      String
  awayTeam      String
  homeScore     Int?
  awayScore     Int?
  stadiumCity   String
  stadiumName   String?
  phase         MatchPhase
  status        MatchStatus @default(SCHEDULED)
  matchDate     DateTime
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  predictions Prediction[]

  @@map("matches")
}

model Prediction {
  id           String   @id @default(uuid())
  homeScoreBet Int
  awayScoreBet Int
  points       Int?     // se calcula al finalizar el partido
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  matchId String
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
  @@map("predictions")
}
